{
  "name": "wechat-ai",
  "version": "0.4.2",
  "description": "WeChat AI Bot — Bridge WeChat to Claude, Qwen, DeepSeek and more",
  "type": "module",
  "bin": {
    "wechat-ai": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "keywords": [
    "wechat",
    "weixin",
    "claude",
    "openai",
    "gemini",
    "ai",
    "bot",
    "gateway",
    "agent",
    "deepseek",
    "qwen"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "claw-agent-sdk": "^0.1.0",
    "express": "^5.2.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
